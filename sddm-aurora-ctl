_INDEX_JSON = THEME_ROOT / "playlists" / "index.json"

_INDEX_DEFAULTS: dict = {
    "version": 1,
    "video": [
        {"label": "All Videos", "path": "playlists/Background.mp4", "default": True}
    ],
    "image": [
        {"label": "Default Image", "path": "backgrounds/background.jpg", "default": True}
    ],
}


def _load_index() -> dict:
    """
    Load playlists/index.json.

    Returns the parsed dict (with 'video' and 'image' lists guaranteed to
    exist).  If the file is absent or malformed, returns the built-in
    defaults so the catalogue is always in a usable state.
    """
    import copy
    data = copy.deepcopy(_INDEX_DEFAULTS)
    if _INDEX_JSON.exists():
        try:
            raw = json.loads(_INDEX_JSON.read_text(encoding="utf-8"))
            if isinstance(raw, dict):
                if isinstance(raw.get("video"), list):
                    data["video"] = raw["video"]
                if isinstance(raw.get("image"), list):
                    data["image"] = raw["image"]
        except (json.JSONDecodeError, OSError) as exc:
            _warn(f"Could not parse {_INDEX_JSON}: {exc}  (using defaults)")
    return data


def _save_index(data: dict) -> None:
    """Persist the catalogue index atomically."""
    _ensure_elevated()
    _atomic_write(_INDEX_JSON, json.dumps(data, indent=2) + "\n")
    _set_perms_644(_INDEX_JSON)
    _ok(f"Catalogue written → {_INDEX_JSON}")


