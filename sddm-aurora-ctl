    # ── scheduler ─────────────────────────────────────────────────────────────
    sub_sched = subparsers.add_parser(
        "scheduler",
        help="configure day/night time-based activation windows",
    )
    sched_sub = sub_sched.add_subparsers(dest="action", metavar="ACTION")

    sched_time = sched_sub.add_parser(
        "set-time",
        help="set the start and end hour for day-mode activation",
    )
    sched_time.add_argument(
        "--day-start",
        required=True,
        metavar="HOUR",
        help="hour (0–23) when day mode begins",
    )
    sched_time.add_argument(
        "--day-end",
        required=True,
        metavar="HOUR",
