    cfg_theme.add_argument(
        "--opacity",
        metavar="FLOAT",
        default=None,
        help="login card background opacity  [0.0 – 1.0]",
    )
    cfg_theme.add_argument(
        "--radius",
        metavar="PIXELS",
        default=None,
        help="border radius in pixels for the login card (integer ≥ 0)",
    )
    cfg_theme.add_argument(
        "--monitor-mode",
        metavar="MODE",
        default=None,
        choices=list(_VALID_MONITOR_MODES),
        help=(
            "multi-monitor mode: "
            "'mirror' | 'primary-only' | 'blank-auxiliary'"
        ),
    )
    # [NEW] Multi-Backdrop Engine controls
    cfg_theme.add_argument(
        "--bg-type",
        metavar="TYPE",
        default=None,
        choices=["video", "image", "slideshow", "color"],
        help="backdrop mode: 'video' | 'image' | 'slideshow' | 'color'",
    )
    cfg_theme.add_argument(
        "--bg-color",
        metavar="COLOR",
        default=None,
        help="solid background hex color for --bg-type color  (e.g. '#1e1e2e')",
