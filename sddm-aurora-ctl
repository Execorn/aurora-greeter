def _wallpaper_set(args: argparse.Namespace) -> None:
    """
    Change the active backdrop.

    Logic:
      1. Classify the input as video / image / playlist / url.
      2. For local files: copy into the appropriate theme subdirectory,
         set 644 permissions, and record the theme-relative path.
      3. For URLs: write the URL directly to activePlaylist (the QML
         engine passes URLs straight to MediaPlayer.source).
      4. Persist the new activePlaylist value to settings.json.
    """
    _heading("wallpaper set")
    _ensure_elevated()

    source = args.source.strip()
    kind = _classify_input(source)

    _info(f"Input:      {source}")
    _info(f"Classified: {kind}")

    active_playlist: str

    if kind == "url":
        # Write URL directly; QML handles streaming via GStreamer
        active_playlist = source
        _ok(f"URL will be used directly as backdrop source.")

    elif kind == "playlist":
        src_path = Path(source).expanduser().resolve()
        if not src_path.exists():
            _die(f"Playlist file not found: {src_path}")

        _ensure_dir(PLAYLISTS_DIR)
        dest = PLAYLISTS_DIR / src_path.name

        if src_path != dest:
            _info(f"Copying → {dest}")
            shutil.copy2(str(src_path), str(dest))
            _set_perms_644(dest)
            _ok(f"Playlist installed: {dest}")
        else:
            _ok(f"Playlist already in playlists/: {dest.name}")

        # Store theme-relative path (what QML resolves against its root)
        active_playlist = "playlists/" + dest.name

    elif kind == "video":
        src_path = Path(source).expanduser().resolve()
        if not src_path.exists():
            _die(f"Video file not found: {src_path}")

        bg_dir = THEME_ROOT / "backgrounds"
        _ensure_dir(bg_dir)
        dest = bg_dir / src_path.name

        _info(f"Copying video → {dest}")
        shutil.copy2(str(src_path), str(dest))
        _set_perms_644(dest)
        _ok(f"Video installed: {dest}")

        active_playlist = "backgrounds/" + dest.name

    elif kind == "image":
        src_path = Path(source).expanduser().resolve()
        if not src_path.exists():
            _die(f"Image file not found: {src_path}")

        bg_dir = THEME_ROOT / "backgrounds"
        _ensure_dir(bg_dir)
        dest = bg_dir / src_path.name

        _info(f"Copying image → {dest}")
        shutil.copy2(str(src_path), str(dest))
        _set_perms_644(dest)
        _ok(f"Image installed: {dest}")

        active_playlist = "backgrounds/" + dest.name

    else:
        _die(f"Unhandled media kind: {kind}")  # Should never happen

    # ── Persist to settings.json ───────────────────────────────────────────────
    _save_settings({"activePlaylist": active_playlist})
    _ok(f"activePlaylist → \"{active_playlist}\"")
    _section()
    _info("Changes take effect at the next SDDM session.")
    print()


