def _load_settings() -> dict:
    """
    Load and return the settings.json dictionary.

    Missing keys are filled in from ``_SETTINGS_DEFAULTS``.
    An absent or unparsable file returns the defaults without error.
    """
    data: dict = dict(_SETTINGS_DEFAULTS)
    if SETTINGS_JSON.exists():
        try:
            raw = json.loads(SETTINGS_JSON.read_text(encoding="utf-8"))
            if isinstance(raw, dict):
                data.update(raw)
        except (json.JSONDecodeError, OSError) as exc:
            _warn(f"Could not parse {SETTINGS_JSON}: {exc}  (using defaults)")
    return data


def _save_settings(data: dict) -> None:
    """
    Persist the settings dictionary to SETTINGS_JSON.

    Writes are atomic and preserve all existing keys (a merge, not replace).
    """
    _ensure_elevated()
    existing = _load_settings()
    existing.update(data)
    _atomic_write(SETTINGS_JSON, json.dumps(existing, indent=2) + "\n")
    _set_perms_644(SETTINGS_JSON)
    _ok(f"Settings written → {SETTINGS_JSON}")


# ─────────────────────────────────────────────────────────────────────────────
#  THEME.CONF.USER  (INI-style)
# ─────────────────────────────────────────────────────────────────────────────

def _load_user_conf() -> configparser.ConfigParser:
    """
    Load theme.conf.user into a ConfigParser.

    If the file does not exist, return an empty parser with a [General]
    section so callers can write to it immediately.
    """
    cp = configparser.ConfigParser(
        # Preserve key case (theme.conf uses camelCase keys)
        strict=False,
        interpolation=None,
    )
    cp.optionxform = str
    # configparser needs at least one section header; our file starts with
    # [General] which satisfies that requirement.
    if USER_CONF.exists():
        try:
            cp.read(USER_CONF, encoding="utf-8")
        except configparser.Error as exc:
            _warn(f"Could not parse {USER_CONF}: {exc}  (starting fresh)")
    if not cp.has_section("General"):
        cp.add_section("General")
    return cp


def _save_user_conf(cp: configparser.ConfigParser) -> None:
    """
    Write the ConfigParser back to theme.conf.user without corrupting it.

    configparser writes a trailing newline after each section header and
    after each key=value pair, which is valid INI syntax and matches the
    existing file style.
    """
    _ensure_elevated()
    import io
    buf = io.StringIO()
    cp.write(buf)
    raw = buf.getvalue()

    # configparser prefixes sections with a blank line and writes keys as
    # "key = value" (with spaces around '='), but theme.conf uses "key=value".
    # Normalise to the existing style:
    raw = raw.replace(" = ", "=")

    _atomic_write(USER_CONF, raw)
    _set_perms_644(USER_CONF)
    _ok(f"User config written → {USER_CONF}")


# ─────────────────────────────────────────────────────────────────────────────
#  INPUT VALIDATION
# ─────────────────────────────────────────────────────────────────────────────

_HEX_COLOR_RE = re.compile(
    r"^#(?:[0-9A-Fa-f]{3}|[0-9A-Fa-f]{6}|[0-9A-Fa-f]{8})$")
_VALID_MONITOR_MODES = {"mirror", "primary-only", "blank-auxiliary"}
_VALID_ORDER_MODES = {"shuffled", "sequential"}

# Media file extensions supported by the QML engine / GStreamer pipeline
_VIDEO_EXTS = {".mp4", ".webm", ".mkv", ".mov", ".avi", ".m4v"}
_IMAGE_EXTS = {".jpg", ".jpeg", ".png", ".bmp", ".gif", ".webp"}
_PLAYLIST_EXTS = {".m3u", ".m3u8"}


def _validate_hex_color(value: str) -> str:
    """
    Validate and normalise a CSS hex colour string.

    Accepts #RGB, #RRGGBB, or #AARRGGBB (case-insensitive).
    Returns the value uppercased on success; calls _die() on failure.
    """
    v = value.strip()
    if not v.startswith("#"):
        v = "#" + v
    if not _HEX_COLOR_RE.match(v):
        _die(
            f"Invalid hex color: '{value}'\n"
            f"       Expected formats: #RGB, #RRGGBB, or #AARRGGBB\n"
            f"       Example: --accent '#89b4fa'"
        )
    return v


def _validate_opacity(value: str) -> float:
    """Parse and validate a float in [0.0 … 1.0]."""
    try:
        f = float(value)
    except ValueError:
        _die(f"Invalid opacity value: '{value}'  (must be a number like 0.72)")
    if not 0.0 <= f <= 1.0:
        _die(f"Opacity {f} is out of range.  Must be between 0.0 and 1.0.")
    return round(f, 4)


def _validate_radius(value: str) -> int:
    """Parse and validate a non-negative integer pixel radius."""
    try:
        n = int(value)
    except ValueError:
        _die(
            f"Invalid radius value: '{value}'  (must be a non-negative integer)")
    if n < 0:
        _die(f"Radius {n} is negative — must be ≥ 0.")
    return n


def _validate_hour(value: str, label: str) -> int:
    """Parse and validate an integer clock-hour in [0 … 23]."""
    try:
        h = int(value)
    except ValueError:
        _die(
            f"Invalid value for {label}: '{value}'  (must be an integer 0–23)")
    if not 0 <= h <= 23:
        _die(f"{label} = {h} is out of range.  Must be between 0 and 23.")
    return h


def _classify_input(path_or_url: str) -> str:
    """
    Classify the wallpaper input as one of:
      'video'    — local video file
      'image'    — local image file
      'playlist' — local .m3u file
      'url'      — http/https/rtsp URL (video or .m3u)
    """
    parsed = urlparse(path_or_url)
    if parsed.scheme in ("http", "https", "rtsp", "rtsps", "mms"):
        return "url"

    p = Path(path_or_url)
    ext = p.suffix.lower()

    if ext in _VIDEO_EXTS:
        return "video"
    if ext in _IMAGE_EXTS:
        return "image"
    if ext in _PLAYLIST_EXTS:
        return "playlist"

    # Unknown extension — try to guess from existence
    if p.exists():
        # Treat unknown local files as video (GStreamer will decide)
        return "video"

    _die(
        f"Cannot classify input: '{path_or_url}'\n"
        f"       Supported: local video ({', '.join(sorted(_VIDEO_EXTS))}),\n"
        f"                  local image ({', '.join(sorted(_IMAGE_EXTS))}),\n"
        f"                  .m3u playlist, or http/https URL."
    )


# ─────────────────────────────────────────────────────────────────────────────
#  SUBCOMMAND A: playlist
# ─────────────────────────────────────────────────────────────────────────────

def _playlist_create(args: argparse.Namespace) -> None:
    """
    Scan <directory> recursively for compatible media and write a .m3u
    playlist to {THEME_ROOT}/playlists/<name>.m3u.

    The .m3u format used here is the extended variant (#EXTM3U header) to
    be compatible with our QML playlist reader.  Each entry gets an
    #EXTINF line with duration=-1 (unknown) and the filename as the title.
    """
    _heading("playlist create")
    _ensure_elevated()

    name = args.name.strip()
    src = Path(args.directory).expanduser().resolve()

    # ── Validation ────────────────────────────────────────────────────────────
    if not src.exists():
        _die(f"Source directory does not exist: {src}")
    if not src.is_dir():
        _die(f"Source path is not a directory: {src}")

    # Sanitise playlist name (no path separators, no double dots)
    safe_name = re.sub(r"[^A-Za-z0-9_\-.]", "_", name)
    safe_name = re.sub(r"\.{2,}", ".", safe_name)
    if not safe_name:
        _die("Playlist name resolves to an empty string after sanitisation.")

    out_path = PLAYLISTS_DIR / f"{safe_name}.m3u"
    _ensure_dir(PLAYLISTS_DIR)

    _info(f"Scanning:  {src}")
    _info(f"Output:    {out_path}")

    # ── File scan ─────────────────────────────────────────────────────────────
    all_exts = _VIDEO_EXTS | _IMAGE_EXTS
    found: list[Path] = []

    for entry in sorted(src.rglob("*")):
        if entry.is_file() and entry.suffix.lower() in all_exts:
            found.append(entry)

    if not found:
        _die(
            f"No compatible media files found in: {src}\n"
            f"       Supported: {', '.join(sorted(all_exts))}"
        )

    _info(f"Found {len(found)} compatible file(s).")

    # ── Build .m3u content ────────────────────────────────────────────────────
    lines: list[str] = ["#EXTM3U", ""]

    for f in found:
        title = f.stem
        lines.append(f"#EXTINF:-1,{title}")
        lines.append(str(f))
        lines.append("")

    content = "\n".join(lines)

    # ── Write ─────────────────────────────────────────────────────────────────
    _atomic_write(out_path, content)
    _set_perms_644(out_path)

    _ok(f"Playlist created: {out_path}")
    _ok(f"Entries: {len(found)}")
    _section()
    _info("To activate:  sddm-aurora-ctl wallpaper set " + str(out_path))
    print()


def _playlist_order(args: argparse.Namespace) -> None:
    """
    Inject or update the #EXT-ORDER directive at the top of an existing
    .m3u playlist file.

    Directive values:
      SHUFFLED    — signals our QML engine to apply Fisher-Yates before play
      SEQUENTIAL  — signals alphabetical / file-order playback
    """
    _heading("playlist order")
    _ensure_elevated()

    name = args.name.strip()
    order = args.order.strip().lower()

    if order not in _VALID_ORDER_MODES:
        _die(
            f"Invalid order mode: '{order}'\n"
            f"       Valid values: {', '.join(sorted(_VALID_ORDER_MODES))}"
        )

    playlist_path = PLAYLISTS_DIR / f"{name}.m3u"
    if not playlist_path.exists():
        # Also try without adding .m3u (user may have typed the full filename)
        alt = PLAYLISTS_DIR / name
        if alt.exists():
            playlist_path = alt
        else:
            _die(
                f"Playlist not found: {playlist_path}\n"
                f"       Available playlists in {PLAYLISTS_DIR}:\n"
                + _list_playlists_str()
            )

    _info(f"Playlist: {playlist_path}")
    _info(f"Order:    {order.upper()}")

    content = playlist_path.read_text(encoding="utf-8")
    lines = content.splitlines(keepends=False)

    directive = f"#EXT-ORDER: {order.upper()}"

    # Remove any existing #EXT-ORDER line
    lines = [ln for ln in lines if not ln.startswith("#EXT-ORDER:")]

    # Insert immediately after #EXTM3U (or at position 0)
    if lines and lines[0].startswith("#EXTM3U"):
        lines.insert(1, directive)
    else:
        lines.insert(0, directive)

    _atomic_write(playlist_path, "\n".join(lines) + "\n")
    _set_perms_644(playlist_path)

    _ok(f"Order directive set: {directive}")
    _ok(f"Playlist updated: {playlist_path}")
    print()


def _list_playlists_str() -> str:
    """Return a formatted list of available .m3u files as a string."""
    if not PLAYLISTS_DIR.exists():
        return "       (playlists directory does not exist)"
    playlists = sorted(PLAYLISTS_DIR.glob("*.m3u"))
    if not playlists:
        return "       (no playlists found)"
    return "\n".join(f"         • {p.name}" for p in playlists)


