def _catalogue_list(args: argparse.Namespace) -> None:
    """
    Print a formatted view of the current catalogue (index.json contents).
    """
    _heading("catalogue list")

    data = _load_index()

    print(f"  {_BOLD_CYAN}Video playlists:{_RESET}")
    for i, entry in enumerate(data.get("video", [])):
        tag = f"{_DIM}[default]{_RESET}" if entry.get("default") else ""
        print(f"    {_GREEN}{i+1}.{_RESET} {_BOLD}{entry.get('label', '?')}{_RESET}  "
              f"{_DIM}{entry.get('path', '?')}{_RESET}  {tag}")
    if not data.get("video"):
        print(f"    {_DIM}(none){_RESET}")

    print()
    print(f"  {_BOLD_CYAN}Image sources:{_RESET}")
    for i, entry in enumerate(data.get("image", [])):
        tag = f"{_DIM}[default]{_RESET}" if entry.get("default") else ""
        print(f"    {_GREEN}{i+1}.{_RESET} {_BOLD}{entry.get('label', '?')}{_RESET}  "
              f"{_DIM}{entry.get('path', '?')}{_RESET}  {tag}")
    if not data.get("image"):
        print(f"    {_DIM}(none){_RESET}")
    print()


def _catalogue_add_video(args: argparse.Namespace) -> None:
    """
    Scan *folder* for video files, create a named .m3u playlist in
    {THEME_ROOT}/playlists/, and register it in index.json.

    The generated playlist uses absolute paths so GStreamer can open the
    files regardless of where SDDM is launched from.
    """
    _heading("catalogue add-video")
    _ensure_elevated()

    label = args.label.strip()
    folder = Path(args.folder).expanduser().resolve()

    if not folder.exists() or not folder.is_dir():
        _die(f"Folder does not exist or is not a directory: {folder}")

    if not label:
        _die("Label must not be empty.")

    # Sanitise label into a safe filename
    safe_name = re.sub(r"[^A-Za-z0-9_\-.]", "_", label)
    safe_name = re.sub(r"\.{2,}", ".", safe_name).strip("_-")
    if not safe_name:
        _die("Label resolves to an empty filename after sanitisation.")

    _info(f"Label:   {label}")
    _info(f"Folder:  {folder}")

    # Scan for video files
    found: list[Path] = sorted(
        f for f in folder.rglob("*")
        if f.is_file() and f.suffix.lower() in _VIDEO_EXTS
    )
    if not found:
        _die(
            f"No video files found in: {folder}\n"
            f"       Supported: {', '.join(sorted(_VIDEO_EXTS))}"
        )
    _info(f"Found {len(found)} video file(s).")

    # Write .m3u playlist
    _ensure_dir(PLAYLISTS_DIR)
    out_path = PLAYLISTS_DIR / f"{safe_name}.m3u"
    lines: list[str] = ["#EXTM3U", ""]
    for f in found:
        lines.append(f"#EXTINF:-1,{f.stem}")
        lines.append(str(f))
        lines.append("")
    _atomic_write(out_path, "\n".join(lines))
    _set_perms_644(out_path)
    _ok(f"Playlist written: {out_path}  ({len(found)} entries)")

    # Register in index.json
    # Store a theme-relative path so the QML engine resolves it against
    # the theme root regardless of where SDDM is installed.
    rel_path = "playlists/" + out_path.name
    data = _load_index()

    # Prevent duplicate labels
    existing_labels = {e.get("label", "") for e in data.get("video", [])}
    if label in existing_labels:
        _warn(f"A video entry named '{label}' already exists — updating path.")
        for e in data["video"]:
            if e.get("label") == label:
                e["path"] = rel_path
    else:
        data.setdefault("video", []).append({"label": label, "path": rel_path})

    _save_index(data)
    _ok(f"Registered in catalogue: \"{label}\" → {rel_path}")
    _section()
    _info("Open the settings drawer (Alt+S) to see the new playlist.")
    print()


def _catalogue_add_image(args: argparse.Namespace) -> None:
    """
    Copy an image file into {THEME_ROOT}/backgrounds/ and register it in
    index.json so the ConfigDrawer can offer it as an image/slideshow source.
    """
    _heading("catalogue add-image")
    _ensure_elevated()

    label = args.label.strip()
    src = Path(args.path).expanduser().resolve()

    if not label:
        _die("Label must not be empty.")
    if not src.exists() or not src.is_file():
        _die(f"Image file does not exist: {src}")
    if src.suffix.lower() not in _IMAGE_EXTS:
        _die(
            f"Unsupported image extension: '{src.suffix}'\n"
            f"       Supported: {', '.join(sorted(_IMAGE_EXTS))}"
        )

    _info(f"Label:  {label}")
    _info(f"Source: {src}")

    # Copy into backgrounds/
    bg_dir = THEME_ROOT / "backgrounds"
    _ensure_dir(bg_dir)
    dest = bg_dir / src.name
    if src != dest:
        _info(f"Copying → {dest}")
        import shutil as _shutil
        _shutil.copy2(str(src), str(dest))
        _set_perms_644(dest)
    _ok(f"Image installed: {dest}")

    # Register in index.json
    rel_path = "backgrounds/" + dest.name
    data = _load_index()

    existing_labels = {e.get("label", "") for e in data.get("image", [])}
    if label in existing_labels:
        _warn(
            f"An image entry named '{label}' already exists — updating path.")
        for e in data["image"]:
            if e.get("label") == label:
                e["path"] = rel_path
    else:
        data.setdefault("image", []).append({"label": label, "path": rel_path})

    _save_index(data)
    _ok(f"Registered in catalogue: \"{label}\" → {rel_path}")
    _section()
    _info("Open the settings drawer (Alt+S) and switch to Image mode to see it.")
    print()


def _catalogue_remove(args: argparse.Namespace) -> None:
    """
    Remove a named entry (video or image) from index.json.

    Does NOT delete the underlying .mp4 / .m3u / image file—only the
    catalogue registration is removed.  The --type flag selects which
    section to search (default: auto-detect from the label).
    """
    _heading("catalogue remove")
    _ensure_elevated()

    label = args.label.strip()
    section = args.type   # "video", "image", or None (auto)

    data = _load_index()
    removed = False

    sections = ([section] if section else ["video", "image"])
    for sec in sections:
        entries = data.get(sec, [])
        filtered = [e for e in entries if e.get("label") != label]
        if len(filtered) < len(entries):
            data[sec] = filtered
            removed = True
            _ok(f"Removed '{label}' from {sec} section.")

    if not removed:
        _die(
            f"No entry named '{label}' found in the catalogue.\n"
            f"       Use 'sddm-aurora-ctl catalogue list' to see available entries."
        )

    _save_index(data)
    _section()
    _info("Changes take effect the next time the settings drawer is opened.")
    print()


