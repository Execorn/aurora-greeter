# ─────────────────────────────────────────────────────────────────────────────
#  PATH RESOLUTION
#  ─────────────────────────────────────────────────────────────────────────────
#  Rules:
#    1. If this script's *real* path lives under a system bin directory
#       (/usr/bin, /usr/local/bin, /bin, /sbin, /usr/sbin), then:
#         THEME_ROOT  = /usr/share/sddm/themes/aurora-greeter
#         SYSTEM_MODE = True   → sudo elevation on write
#    2. Otherwise (development, running from the repo):
#         THEME_ROOT  = directory that contains this file
#         SYSTEM_MODE = False  → no elevation
#
#  JSON settings file:
#    • Prefer  /var/lib/sddm/.config/AuroraGreeter/settings.json
#    • Fall back to {THEME_ROOT}/settings.json when /var/lib/ is not writable
#      (common during local, non-root development).
# ─────────────────────────────────────────────────────────────────────────────


_SYSTEM_BIN_PREFIXES = (
    "/usr/bin",
    "/usr/local/bin",
    "/bin",
    "/sbin",
    "/usr/sbin",
    "/usr/local/sbin",
)

_SYSTEM_THEME_ROOT = Path("/usr/share/sddm/themes/aurora-greeter")
_SYSTEM_SETTINGS = Path("/var/lib/sddm/.config/AuroraGreeter/settings.json")


def _resolve_paths() -> tuple[Path, Path, Path, Path, bool]:
    """
    Resolve all runtime paths.

    Returns:
        (THEME_ROOT, PLAYLISTS_DIR, USER_CONF, SETTINGS_JSON, SYSTEM_MODE)
    """
    script_real = Path(os.path.realpath(__file__))
    script_dir = script_real.parent

    # Determine whether we are in system-installed mode
    system_mode = any(
        str(script_real).startswith(prefix)
        for prefix in _SYSTEM_BIN_PREFIXES
    )

    if system_mode:
        theme_root = _SYSTEM_THEME_ROOT
    else:
        theme_root = script_dir

    playlists_dir = theme_root / "playlists"
    user_conf = theme_root / "theme.conf.user"

    # Choose settings.json path
    if _SYSTEM_SETTINGS.parent.exists():
        # /var/lib/sddm/.config/AuroraGreeter exists (or can be created)
        settings_json = _SYSTEM_SETTINGS
    elif system_mode:
        # System mode but /var/lib/sddm not yet created — will be created later
        settings_json = _SYSTEM_SETTINGS
    else:
        # Local dev: fall back gracefully to a local settings.json
        settings_json = theme_root / "settings.json"

    return theme_root, playlists_dir, user_conf, settings_json, system_mode


THEME_ROOT, PLAYLISTS_DIR, USER_CONF, SETTINGS_JSON, SYSTEM_MODE = _resolve_paths()

# ─────────────────────────────────────────────────────────────────────────────
#  PRIVILEGE ELEVATION HELPERS
# ─────────────────────────────────────────────────────────────────────────────


def _is_root() -> bool:
    """Return True when the process is running as UID 0 (root)."""
    return os.geteuid() == 0


def _need_elevation() -> bool:
    """
    Return True if a write operation requires privilege elevation.

    Only raises this flag when in system mode AND not already root.
    Local development mode never requires sudo.
    """
    return SYSTEM_MODE and not _is_root()


def _reexec_with_sudo() -> None:
    """
    Re-execute the current process via sudo, preserving all arguments.

    This is called before any write operation when running in system mode
    without root privileges.  The function replaces the current process
    image (execvp), so it never returns on success.
    """
    _warn("Write operation requires elevated privileges.")
    _info("Re-launching with sudo — you may be prompted for your password.")
    print()

    sudo_cmd = ["sudo", sys.executable] + sys.argv
    try:
        os.execvp("sudo", sudo_cmd)
    except FileNotFoundError:
        _die("'sudo' was not found on PATH.  Re-run this command as root.")
    except PermissionError as exc:
        _die(f"Failed to exec sudo: {exc}")


def _ensure_elevated() -> None:
    """
    Gate function for write operations.

    If elevation is required but not yet active, re-exec via sudo.
    If already root or in local mode, this is a no-op.
    """
    if _need_elevation():
        _reexec_with_sudo()
        # If _reexec_with_sudo() returns (only on failure), die.
        _die("Privilege re-exec failed.")

# ─────────────────────────────────────────────────────────────────────────────
#  FILE / DIRECTORY UTILITIES
# ─────────────────────────────────────────────────────────────────────────────


def _ensure_dir(path: Path) -> None:
    """Create a directory (and all parents) if it does not exist."""
    try:
        path.mkdir(parents=True, exist_ok=True)
    except PermissionError:
        _die(f"Permission denied creating directory: {path}")
    except OSError as exc:
        _die(f"Could not create directory {path}: {exc}")


def _set_perms_644(path: Path) -> None:
    """Set file permissions to 644 (rw-r--r--)."""
    try:
        path.chmod(stat.S_IRUSR | stat.S_IWUSR | stat.S_IRGRP | stat.S_IROTH)
    except OSError as exc:
        _warn(f"Could not set permissions on {path}: {exc}")


def _atomic_write(path: Path, content: str) -> None:
    """
    Write *content* to *path* atomically (write to .tmp, then rename).

    This prevents a half-written file from being read by the QML engine
    if an interrupt occurs mid-write.
    """
    _ensure_dir(path.parent)
    tmp = path.with_suffix(path.suffix + ".tmp")
    try:
        tmp.write_text(content, encoding="utf-8")
        tmp.replace(path)
    except PermissionError:
        _die(f"Permission denied writing to {path}.\n"
             f"       Hint: run as root or check directory ownership.")
    except OSError as exc:
        _die(f"Write failed for {path}: {exc}")


