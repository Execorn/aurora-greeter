def _scheduler_set_time(args: argparse.Namespace) -> None:
    """
    Update day_time_start and day_time_end in theme.conf.user.

    The file is parsed with configparser to preserve all existing keys
    while updating only the two time fields.  If the file does not exist
    it is created fresh with a [General] section.
    """
    _heading("scheduler set-time")
    _ensure_elevated()

    day_start = _validate_hour(str(args.day_start), "--day-start")
    day_end = _validate_hour(str(args.day_end),   "--day-end")

    if day_start == day_end:
        _warn(
            f"day_time_start ({day_start}) equals day_time_end ({day_end}). "
            "The day/night window will be zero-length — day mode never activates."
        )

    _info(f"Day window: {day_start:02d}:00 → {day_end:02d}:00")
    _info(f"Config:     {USER_CONF}")

    cp = _load_user_conf()
    cp.set("General", "day_time_start", str(day_start))
    cp.set("General", "day_time_end",   str(day_end))
    _save_user_conf(cp)

    _ok(f"day_time_start = {day_start}")
    _ok(f"day_time_end   = {day_end}")
    _section()
    _info("Changes take effect at the next SDDM session.")
    print()


# ─────────────────────────────────────────────────────────────────────────────
#  SUBCOMMAND D: config
# ─────────────────────────────────────────────────────────────────────────────

def _config_set_theme(args: argparse.Namespace) -> None:
    """
    Update one or more aesthetic parameters in settings.json.

    Each flag is optional; only specified flags are written.  Unspecified
    values retain their current values in settings.json.
    """
    _heading("config set-theme")

    # ── Validate all provided arguments before touching any file ──────────────
    updates: dict = {}

    if args.accent is not None:
        color = _validate_hex_color(args.accent)
        updates["accentColor"] = color
        _info(f"accentColor   → {color}")

    if args.opacity is not None:
        opacity = _validate_opacity(args.opacity)
        updates["loginCardOpacity"] = opacity
        _info(f"loginCardOpacity → {opacity}")

    if args.radius is not None:
        radius = _validate_radius(args.radius)
        # borderRadius lives in theme.conf / theme.conf.user (not settings.json)
        # We write it to user conf so the QML engine picks it up.
        _info(f"borderRadius  → {radius}px  (written to theme.conf.user)")

    if args.monitor_mode is not None:
        mode = args.monitor_mode.strip().lower()
        if mode not in _VALID_MONITOR_MODES:
            _die(
                f"Invalid monitor mode: '{mode}'\n"
                f"       Valid values: {', '.join(sorted(_VALID_MONITOR_MODES))}"
            )
        updates["activeMultiMonitorMode"] = mode
        _info(f"activeMultiMonitorMode → {mode}")

    # [NEW] backdrop type
    if args.bg_type is not None:
        bg = args.bg_type.strip().lower()
        valid_bg = {"video", "image", "slideshow", "color"}
        if bg not in valid_bg:
            _die(
                f"Invalid backdrop type: '{bg}'\n"
                f"       Valid values: {', '.join(sorted(valid_bg))}"
            )
        updates["activeBackgroundType"] = bg
        _info(f"activeBackgroundType  → {bg}")

    # [NEW] background color
    if args.bg_color is not None:
        color = _validate_hex_color(args.bg_color)
        updates["backgroundColor"] = color
        _info(f"backgroundColor       → {color}")

    # [NEW] slideshow interval
    if args.slideshow_interval is not None:
        try:
            iv = int(args.slideshow_interval)
        except ValueError:
            _die(
                f"Invalid slideshow interval: '{args.slideshow_interval}'  (must be an integer)")
        if not 5 <= iv <= 60:
            _die(
                f"Slideshow interval {iv} is out of range.  Must be between 5 and 60 seconds.")
        updates["slideshowInterval"] = iv
        _info(f"slideshowInterval     → {iv}s")

    # [NEW v4] performance mode
    if args.performance_mode is not None:
        pm = args.performance_mode.strip().lower()
        if pm not in {"auto", "high", "low"}:
            _die(
                f"Invalid performance mode: '{pm}'\n"
                f"       Valid values: auto | high | low"
            )
        updates["performanceMode"] = pm
        _info(f"performanceMode       → {pm}")

    if not updates and args.radius is None:
        _die(
            "No options specified.  At least one of --accent, --opacity, "
            "--radius, --monitor-mode, --bg-type, --bg-color, "
            "--slideshow-interval, or --performance-mode is required."
        )

    _ensure_elevated()

    # ── Write settings.json ───────────────────────────────────────────────────
    if updates:
        _save_settings(updates)

    # ── Write borderRadius to theme.conf.user ─────────────────────────────────
    if args.radius is not None:
        radius = _validate_radius(args.radius)
        cp = _load_user_conf()
        cp.set("General", "borderRadius", str(radius))
        _save_user_conf(cp)
        _ok(f"borderRadius = {radius}px → {USER_CONF}")

    _section()
    _info("Changes take effect at the next SDDM session.")
    print()


# ─────────────────────────────────────────────────────────────────────────────
#  SUBCOMMAND E: hw-accel
#
#  Thin Python wrapper around install-hw-accel.sh.
#  Resolves the shell script path relative to the same directory as this
#  Python script (or the theme root in system mode) and exec-forwards
#  arguments.  All heavy logic lives in the shell script.
# ─────────────────────────────────────────────────────────────────────────────

def _hw_accel_script_path() -> Path:
    """
    Locate install-hw-accel.sh alongside this Python script.

    In development mode the script and the shell script are siblings in the
    same directory.  In system-installed mode the shell script is expected
    at THEME_ROOT (e.g. /usr/share/sddm/themes/aurora-greeter/install-hw-accel.sh)
    or alongside the ctl binary in /usr/bin/ or /usr/share/sddm/themes/aurora-greeter/.
    """
    candidates = [
        Path(os.path.realpath(__file__)).parent / "install-hw-accel.sh",
        THEME_ROOT / "install-hw-accel.sh",
    ]
    for c in candidates:
        if c.exists():
            return c
    return candidates[0]   # return primary path even if missing (error later)


def _hw_accel_run(action: str, extra_args: list[str]) -> None:
    """
    Execute install-hw-accel.sh with the given action flag.

    The shell script performs its own root check for install/uninstall;
    we simply forward stdin/stdout/stderr.
    """
    import subprocess

    script = _hw_accel_script_path()
    if not script.exists():
        _die(
            f"install-hw-accel.sh not found at: {script}\n"
            f"       Ensure the file ships alongside sddm-aurora-ctl."
        )

    # Ensure the script is executable
    if not os.access(str(script), os.X_OK):
        try:
            script.chmod(script.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP)
        except OSError as exc:
            _warn(f"Could not mark {script} as executable: {exc}")

    cmd = ["bash", str(script), f"--{action}"] + extra_args
    try:
        result = subprocess.run(cmd, check=False)
        sys.exit(result.returncode)
    except FileNotFoundError:
        _die("bash not found on PATH.")


def _hw_accel_install(args: argparse.Namespace) -> None:
    """Install the GStreamer HW acceleration systemd drop-in."""
    _heading("hw-accel install")
    extra: list[str] = []
    if getattr(args, "dry_run", False):
        extra.append("--dry-run")
    if getattr(args, "force_gpu", None):
        extra += ["--force-gpu", args.force_gpu]
    _hw_accel_run("install", extra)


def _hw_accel_uninstall(args: argparse.Namespace) -> None:
    """Remove the GStreamer HW acceleration systemd drop-in."""
    _heading("hw-accel uninstall")
    extra: list[str] = []
    if getattr(args, "dry_run", False):
        extra.append("--dry-run")
    _hw_accel_run("uninstall", extra)


def _hw_accel_status(args: argparse.Namespace) -> None:
    """Show hardware detection results and current drop-in state."""
    _heading("hw-accel status")
    _hw_accel_run("status", [])


# ─────────────────────────────────────────────────────────────────────────────
#  SUBCOMMAND E: status  (diagnostic overview — bonus quality-of-life command)
# ─────────────────────────────────────────────────────────────────────────────

def _status(args: argparse.Namespace) -> None:
    """
    Print a diagnostic overview of all resolved paths and current settings.
    Useful for troubleshooting both development and system deployments.
    """
    _heading("status / diagnostic overview")

    mode_label = (
        f"{_BOLD_RED}SYSTEM (writes require root){_RESET}" if SYSTEM_MODE
        else f"{_BOLD_GREEN}LOCAL DEVELOPMENT{_RESET}"
    )

    print(f"  {_BOLD}Operating mode:{_RESET}  {mode_label}")
    print(f"  {_BOLD}Running as:{_RESET}      {'root (UID 0)' if _is_root() else f'user UID {os.getuid()}'}")
    print()

    # Paths
    rows = [
        ("THEME_ROOT",    THEME_ROOT),
        ("PLAYLISTS_DIR", PLAYLISTS_DIR),
        ("USER_CONF",     USER_CONF),
        ("SETTINGS_JSON", SETTINGS_JSON),
    ]
    print(f"  {_BOLD_CYAN}Resolved paths:{_RESET}")
    for label, path in rows:
        exists_tag = (
            f"{_GREEN}✔ exists{_RESET}" if path.exists()
            else f"{_YELLOW}✘ missing{_RESET}"
        )
        print(f"    {_DIM}{label:<16}{_RESET}  {path}  [{exists_tag}]")
    print()

    # Current settings.json
    print(f"  {_BOLD_CYAN}Current settings.json:{_RESET}")
    settings = _load_settings()
    for key, val in settings.items():
        print(f"    {_DIM}{key:<26}{_RESET}  {_BOLD}{val}{_RESET}")
    print()

    # Available playlists
    print(f"  {_BOLD_CYAN}Available playlists:{_RESET}")
    print(_list_playlists_str())
    print()

    # Catalogue index
    index_data = _load_index()
    print(f"  {_BOLD_CYAN}Catalogue index  [{_INDEX_JSON}]:{_RESET}")
    print(f"    {_DIM}Video entries:{_RESET}")
    for e in index_data.get("video", []):
        tag = " [default]" if e.get("default") else ""
        print(f"      • {e.get('label', '?')} → {e.get('path', '?')}{tag}")
    print(f"    {_DIM}Image entries:{_RESET}")
    for e in index_data.get("image", []):
        tag = " [default]" if e.get("default") else ""
        print(f"      • {e.get('label', '?')} → {e.get('path', '?')}{tag}")
    print()

    # Current theme.conf.user
    print(f"  {_BOLD_CYAN}theme.conf.user  [{USER_CONF}]:{_RESET}")
    if USER_CONF.exists():
        cp = _load_user_conf()
        for key, val in cp.items("General"):
            print(f"    {_DIM}{key:<26}{_RESET}  {val}")
    else:
        print(
            f"    {_YELLOW}(file does not exist — defaults from theme.conf are used){_RESET}")
    print()


# ─────────────────────────────────────────────────────────────────────────────
#  ARGUMENT PARSER
# ─────────────────────────────────────────────────────────────────────────────

def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="sddm-aurora-ctl",
        description=(
            "Command-line companion for the Aurora Greeter theme.\n"
            "Manages playlists, wallpapers, scheduler timings, and config."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            f"Examples:\n"
            f"  sddm-aurora-ctl status\n"
            f"  sddm-aurora-ctl catalogue list\n"
            f"  sddm-aurora-ctl catalogue add-video 'City Nights' ~/Videos/city\n"
            f"  sddm-aurora-ctl catalogue add-image 'Mountain' ~/Pictures/mountain.jpg\n"
            f"  sddm-aurora-ctl catalogue remove 'City Nights'\n"
            f"  sddm-aurora-ctl playlist create myvids ~/Videos/wallpapers\n"
            f"  sddm-aurora-ctl playlist order myvids shuffled\n"
            f"  sddm-aurora-ctl wallpaper set ~/Videos/city.mp4\n"
            f"  sddm-aurora-ctl wallpaper set https://example.com/live.m3u8\n"
            f"  sddm-aurora-ctl scheduler set-time --day-start 7 --day-end 20\n"
            f"  sddm-aurora-ctl config set-theme --accent '#89b4fa' --opacity 0.85\n"
            f"  sddm-aurora-ctl config set-theme --monitor-mode primary-only\n"
        ),
    )

    subparsers = parser.add_subparsers(dest="command", metavar="COMMAND")

    # ── status ────────────────────────────────────────────────────────────────
    sub_status = subparsers.add_parser(
        "status",
        help="show diagnostic overview of paths and current settings",
    )
    sub_status.set_defaults(func=_status)

    # ── catalogue ─────────────────────────────────────────────────────────────
    sub_cat = subparsers.add_parser(
        "catalogue",
        help="manage the playlist / image-source catalogue (index.json)",
        description=(
            "Manages playlists/index.json which the ConfigDrawer reads to\n"
            "populate its playlist and image-source picker dynamically.\n"
            "Changes appear in the settings drawer immediately on next open."
        ),
    )
    cat_sub = sub_cat.add_subparsers(dest="action", metavar="ACTION")

    # catalogue list
    cat_list = cat_sub.add_parser(
        "list",
        help="show all registered video and image catalogue entries",
    )
    cat_list.set_defaults(func=_catalogue_list)

    # catalogue add-video
    cat_av = cat_sub.add_parser(
        "add-video",
        help="scan a folder for videos, create a playlist, register in catalogue",
    )
    cat_av.add_argument(
        "label",
        help="display name shown in the settings drawer  (e.g. 'My Landscapes')",
    )
    cat_av.add_argument(
        "folder",
        help="directory to scan recursively for video files",
    )
    cat_av.set_defaults(func=_catalogue_add_video)

    # catalogue add-image
    cat_ai = cat_sub.add_parser(
        "add-image",
        help="register an image file as a selectable image / slideshow source",
    )
    cat_ai.add_argument(
        "label",
        help="display name shown in the settings drawer  (e.g. 'Mountain Sunset')",
    )
    cat_ai.add_argument(
        "path",
        help="absolute path to the image file to install",
    )
    cat_ai.set_defaults(func=_catalogue_add_image)

    # catalogue remove
    cat_rm = cat_sub.add_parser(
        "remove",
        help="remove a named entry from the catalogue (does not delete the file)",
    )
    cat_rm.add_argument(
        "label",
        help="exact display name of the entry to remove",
    )
    cat_rm.add_argument(
        "--type",
        metavar="SECTION",
        default=None,
        choices=["video", "image"],
        help="restrict search to 'video' or 'image' section  (default: search both)",
    )
    cat_rm.set_defaults(func=_catalogue_remove)

    # ── playlist ──────────────────────────────────────────────────────────────
    sub_pl = subparsers.add_parser(
        "playlist",
        help="manage video/image playlists (.m3u)",
    )

    pl_sub = sub_pl.add_subparsers(dest="action", metavar="ACTION")

    # playlist create
    pl_create = pl_sub.add_parser(
        "create",
        help="scan a directory and generate a .m3u playlist",
    )
    pl_create.add_argument(
        "name",
        help="playlist name (no extension); e.g. 'summer_nights'",
    )
    pl_create.add_argument(
        "directory",
        help="directory to scan for media files (recursive)",
    )
    pl_create.set_defaults(func=_playlist_create)

    # playlist order
    pl_order = pl_sub.add_parser(
        "order",
        help="set playback order hint on an existing playlist",
