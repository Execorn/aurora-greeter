    cfg_theme.add_argument(
        "--slideshow-interval",
        metavar="SECONDS",
        default=None,
        help="slideshow image duration in seconds  [5–60]",
    )
    # [NEW v4] Performance profile
    cfg_theme.add_argument(
        "--performance-mode",
        metavar="MODE",
        default=None,
        choices=["auto", "high", "low"],
        help=(
            "video rendering quality profile:\n"
            "  auto  — screen-adaptive (default): ≤1920px wide → 2K, wider → 4K\n"
            "  high  — always use highest available quality (may be 4K)\n"
            "  low   — force 2K URLs + fast animations (best for iGPU)"
