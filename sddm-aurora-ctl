    cfg_theme.set_defaults(func=_config_set_theme)

    # ── hw-accel ──────────────────────────────────────────────────────────────────
    sub_hw = subparsers.add_parser(
        "hw-accel",
        help="GStreamer hardware acceleration: install / remove / status",
        description=(
            "Installs or removes a systemd drop-in that configures GStreamer\n"
            "hardware video decode (NVDEC, VA-API) for the SDDM service.\n"
            "Reduces CPU decode load on low-profile hardware."
        ),
    )
    hw_sub = sub_hw.add_subparsers(dest="action", metavar="ACTION")

    # hw-accel install
    hw_install = hw_sub.add_parser(
        "install",
        help="auto-detect GPU and install the GStreamer HW decode drop-in",
    )
    hw_install.add_argument(
        "--force-gpu",
        metavar="TYPE",
        default=None,
        choices=["nvidia", "amd", "intel"],
        help="override GPU auto-detection: nvidia | amd | intel",
