    hw_install.set_defaults(func=_hw_accel_install)

    # hw-accel uninstall
    hw_uninstall = hw_sub.add_parser(
        "uninstall",
        help="remove the GStreamer HW decode drop-in",
    )
    hw_uninstall.add_argument(
        "--dry-run",
        action="store_true",
        default=False,
        help="print what would be removed without making changes",
    )
    hw_uninstall.set_defaults(func=_hw_accel_uninstall)

    # hw-accel status
    hw_status = hw_sub.add_parser(
        "status",
        help="show detected hardware and current drop-in state",
    )
    hw_status.set_defaults(func=_hw_accel_status)

    return parser


# ─────────────────────────────────────────────────────────────────────────────
#  ENTRY POINT
# ─────────────────────────────────────────────────────────────────────────────

def main() -> None:
    _banner()

    # Show resolved environment summary at the start of every invocation so
    # operators always know which paths are being used.
    mode_tag = (
        f"{_BOLD_RED}[SYSTEM]{_RESET}" if SYSTEM_MODE
        else f"{_BOLD_GREEN}[LOCAL DEV]{_RESET}"
    )
    print(f"  Mode:        {mode_tag}")
    print(f"  Theme root:  {_DIM}{THEME_ROOT}{_RESET}")
    print(f"  Settings:    {_DIM}{SETTINGS_JSON}{_RESET}")
    print()

    parser = _build_parser()
    args = parser.parse_args()

    if args.command is None:
        parser.print_help()
        sys.exit(0)

    # Dispatch to subcommand; every subparser sets args.func
    if not hasattr(args, "func"):
        # The user typed a top-level subcommand but no action under it
        # (e.g. 'sddm-aurora-ctl playlist' with no 'create' or 'order').
        # Print the relevant sub-help.
        parser.parse_args([args.command, "--help"])
        sys.exit(0)

    try:
        args.func(args)
    except KeyboardInterrupt:
        print()
        _warn("Interrupted by user.")
        sys.exit(130)


if __name__ == "__main__":
    main()
